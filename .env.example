# Frontend Environment Variables
# Base URL for FastAPI backend
NEXT_PUBLIC_FASTAPI_BASE_URL=http://127.0.0.1:8000

# Backend Environment Variables  
# PostgreSQL database connection string
DATABASE_URL=postgresql://user:password@localhost:5432/fraud_detection_agent

# Groq API key for LLM-powered fraud investigation
# Get your key from: https://console.groq.com/keys
GROQ_API_KEY=your_groq_api_key_here

# Optional: Environment name (development, staging, production)
ENVIRONMENT=development
