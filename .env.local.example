# Frontend Environment Configuration Template
# Copy this file to .env.local and fill in your values

# ========================================
# API ENDPOINT CONFIGURATION
# ========================================
# FastAPI backend URL for API calls
# Local development: http://127.0.0.1:8000
# Production: https://api.yourdomain.com
NEXT_PUBLIC_FASTAPI_BASE_URL=http://127.0.0.1:8000

# Fallback URL used in server-side rendering (if needed)
# Usually same as NEXT_PUBLIC_FASTAPI_BASE_URL
FASTAPI_BASE_URL=http://127.0.0.1:8000

# ========================================
# DEVELOPMENT HINTS
# ========================================
# Ensure the backend server is running on the specified URL
# Backend command: python -m uvicorn backend.main:app --reload --port 8000
#
# The frontend will call this URL for all API operations:
# - GET /dashboard
# - GET /transactions
# - GET /alerts
# - GET /memories
# - POST /memory/search
# - POST /memory/store
# - POST /investigate
# - POST /feedback
# - GET /hindsight/similar-cases
